{
  "schema_version": "1.0",
  "format": "markdown",
  "required_fields": [
    "Schema-Version: 1.0",
    "Spec-ID",
    "Status",
    "Domains",
    "Problem",
    "Goals",
    "Non-Goals",
    "Requirements",
    "Acceptance Criteria",
    "Implementation Tickets",
    "Security Model",
    "Tool Research Plan",
    "Validation Plan",
    "Traceability"
  ],
  "acceptance_criteria": {
    "id_format": "AC-001",
    "required_subfields": ["Files", "Validation"]
  },
  "security_acceptance_criteria": {
    "id_format": "SEC-001",
    "required_subfields": ["Threat or risk", "Control", "Validation"]
  },
  "implementation_tickets": {
    "id_format": "TICKET-001",
    "required_subfields": ["Domain", "Linked AC", "Intent", "Likely Files", "Dependencies", "Security Notes", "Validation"]
  },
  "traceability_table": ["Changed File", "AC ID", "Validation Command", "Notes"],
  "status_values": ["draft", "active", "implemented", "superseded"]
}
