{
  "name": "local-codexai-plugins",
  "interface": {
    "displayName": "Local CodexAI Plugins"
  },
  "plugins": [
    {
      "name": "codexai-agentic-workflow",
      "source": {
        "source": "local",
        "path": "./"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Productivity",
      "integrations": {
        "github": {
          "cli": "gh",
          "authentication": "ON_INSTALL",
          "authCommand": "gh auth login",
          "credentialPolicy": "Use GitHub CLI credential storage; never persist tokens in plugin files."
        }
      }
    }
  ]
}
