{
  "description": "CodexAI readiness preflight for Claude Code sessions.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/skills/codex-runtime-hook/scripts/runtime_hook.py\" --project-root \"${CLAUDE_PROJECT_DIR}\" --format prompt",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
